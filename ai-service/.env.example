# ============================================================
# AI Service Configuration
# Copy this file to `.env` and fill in your API keys.
# ============================================================

# --- LLM Provider (one of: anthropic | groq) ---
LLM_PROVIDER=groq

# Anthropic Claude (production)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Groq (free, dev/fallback)
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# --- Embedding Provider (one of: openai | sentence_transformer) ---
EMBED_PROVIDER=sentence_transformer

# OpenAI (production, 1536-dim)
OPENAI_API_KEY=
OPENAI_EMBED_MODEL=text-embedding-3-small

# SentenceTransformer (free local, 384-dim)
ST_EMBED_MODEL=all-MiniLM-L6-v2

# --- Scoring (Cosine Normalization) ---
# all-MiniLM cosine range for CV/JD pairs is ~0.2–0.8
# Stretch to 0–1 for fair scoring. Tune if using OpenAI embeddings.
COSINE_MIN=0.20
COSINE_MAX=0.80

# --- Default Scoring Weights (sum must = 1.0) ---
DEFAULT_WEIGHT_SEMANTIC=0.30
DEFAULT_WEIGHT_SKILLS=0.35
DEFAULT_WEIGHT_EXPERIENCE=0.20
DEFAULT_WEIGHT_EDUCATION=0.10
DEFAULT_WEIGHT_KEYWORDS=0.05

# --- Server ---
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info
